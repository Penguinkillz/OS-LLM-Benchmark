NEXT_PUBLIC_APP_NAME=OS-LLM-Benchmark

# PostgreSQL (required for dashboard, runs, leaderboard)
# Must match docker-compose db: user osllm, password osllm, database osllm.
# If you see password authentication failed, fix this URL or reset the Docker volume: docker compose down -v
DATABASE_URL=postgresql://osllm:osllm@127.0.0.1:5432/osllm?sslmode=disable

REDIS_URL=redis://localhost:6379/0

# Worker: URL the Next.js server calls (server-side only; not exposed to the browser).
WORKER_BASE_URL=http://127.0.0.1:8081

# Optional but recommended: shared secret between Next.js and the worker.
# When set, the worker requires the same value in the X-API-Key header on /assess and /runs.
# Set the same string in both processes. Leave empty for local-only dev with no auth.
WORKER_API_KEY=change-me

# Hugging Face token (optional; for private or gated models)
# HUGGING_FACE_HUB_TOKEN=

# Force device: cpu | cuda | mps (optional)
# OSLLM_DEVICE=cuda
